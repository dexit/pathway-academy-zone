{
    "$schema": "https://playground.wordpress.net/blueprint-schema.json",
    "landingPage": "/wp-admin/",
    "preferredPhpVersion": "8.1",
    "steps": [
        {
            "step": "installTheme",
            "themeZipFile": {
                "resource": "wordpress.org/themes/twentytwentyfour"
            }
        },
        {
            "step": "installPlugin",
            "pluginZipFile": {
                "resource": "wordpress.org/plugins/advanced-custom-fields"
            }
        },
        {
            "step": "activateTheme",
            "themeId": "pathway-academy-zone"
        },
        {
            "step": "activatePlugin",
            "pluginId": "paz-core"
        },
        {
            "step": "importWxr",
            "file": {
                "resource": "file",
                "path": "demo-content/demo.xml"
            }
        }
    ]
}
