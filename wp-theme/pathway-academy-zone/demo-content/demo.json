			"content": "<!-- wp:group {\"backgroundColor\":\"muted\",\"style\":{\"spacing\":{\"padding\":{\"top\":\"5rem\",\"bottom\":\"5rem\"}}},\"layout\":{\"type\":\"constrained\"}} --><div class=\"wp-block-group has-muted-background-color has-background\" style=\"padding-top:5rem;padding-bottom:5rem\"><!-- wp:heading {\"textAlign\":\"center\",\"level\":1} --><h1 class=\"wp-block-heading has-text-align-center\">Frequently Asked Questions</h1><!-- /wp:heading --><!-- wp:paragraph {\"align\":\"center\"} --><p class=\"has-text-align-center\">Answers to the questions we hear most often from parents, carers and schools.</p><!-- /wp:paragraph --></div><!-- /wp:group -->\n<!-- wp:pazone/accordion-faq /-->\n<!-- wp:pattern {\"slug\":\"pathway-academy-zone/cta\"} /-->"
