		{
			"slug": "about",
			"title": "About Us",
			"content": "<!-- wp:group {\"backgroundColor\":\"muted\",\"style\":{\"spacing\":{\"padding\":{\"top\":\"5rem\",\"bottom\":\"5rem\"}}},\"layout\":{\"type\":\"constrained\"}} --><div class=\"wp-block-group has-muted-background-color has-background\" style=\"padding-top:5rem;padding-bottom:5rem\"><!-- wp:heading {\"textAlign\":\"center\",\"level\":1} --><h1 class=\"wp-block-heading has-text-align-center\">About Pathway Academy Zone</h1><!-- /wp:heading --><!-- wp:paragraph {\"align\":\"center\"} --><p class=\"has-text-align-center\">We are a specialist Alternative Provision in Stoke-on-Trent supporting young people aged 11&ndash;16 who benefit from an alternative to mainstream education.</p><!-- /wp:paragraph --></div><!-- /wp:group -->\n<!-- wp:pattern {\"slug\":\"pathway-academy-zone/approach\"} /-->\n<!-- wp:pattern {\"slug\":\"pathway-academy-zone/values\"} /-->\n<!-- wp:pazone/stat-grid /-->\n<!-- wp:pattern {\"slug\":\"pathway-academy-zone/cta\"} /-->"
