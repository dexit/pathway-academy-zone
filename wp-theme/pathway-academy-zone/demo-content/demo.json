		{
			"slug": "knowledge-hub",
			"title": "Knowledge Hub",
			"content": "<!-- wp:group {\"backgroundColor\":\"primary\",\"textColor\":\"background\",\"style\":{\"spacing\":{\"padding\":{\"top\":\"5rem\",\"bottom\":\"5rem\"}}},\"layout\":{\"type\":\"constrained\"}} --><div class=\"wp-block-group has-background-color has-primary-background-color has-text-color has-background\" style=\"padding-top:5rem;padding-bottom:5rem\"><!-- wp:heading {\"textAlign\":\"center\",\"level\":1} --><h1 class=\"wp-block-heading has-text-align-center\">Knowledge Hub</h1><!-- /wp:heading --><!-- wp:paragraph {\"align\":\"center\"} --><p class=\"has-text-align-center\">Your comprehensive resource for understanding Alternative Provision. Expert guides, practical comparisons and evidence-based best practices.</p><!-- /wp:paragraph --></div><!-- /wp:group -->\n<!-- wp:query {\"queryId\":40,\"query\":{\"perPage\":12,\"postType\":\"paz_resource\",\"inherit\":false}} --><div class=\"wp-block-query\"><!-- wp:post-template {\"layout\":{\"type\":\"grid\",\"columnCount\":3}} --><!-- wp:post-featured-image /--><!-- wp:post-title {\"isLink\":true} /--><!-- wp:post-excerpt /--><!-- /wp:post-template --></div><!-- /wp:query -->\n<!-- wp:columns --><div class=\"wp-block-columns\"><!-- wp:column --><div class=\"wp-block-column\"><!-- wp:heading {\"level\":3} --><h3>Glossary</h3><!-- /wp:heading --><!-- wp:paragraph --><p>Plain-English definitions of common terms.</p><!-- /wp:paragraph --><!-- wp:buttons --><div class=\"wp-block-buttons\"><!-- wp:button --><div class=\"wp-block-button\"><a class=\"wp-block-button__link wp-element-button\" href=\"/knowledge-hub/glossary\">Browse glossary</a></div><!-- /wp:button --></div><!-- /wp:buttons --></div><!-- /wp:column --><!-- wp:column --><div class=\"wp-block-column\"><!-- wp:heading {\"level\":3} --><h3>Complete Guide</h3><!-- /wp:heading --><!-- wp:paragraph --><p>An end-to-end walkthrough of Alternative Provision.</p><!-- /wp:paragraph --><!-- wp:buttons --><div class=\"wp-block-buttons\"><!-- wp:button --><div class=\"wp-block-button\"><a class=\"wp-block-button__link wp-element-button\" href=\"/knowledge-hub/complete-guide\">Read the guide</a></div><!-- /wp:button --></div><!-- /wp:buttons --></div><!-- /wp:column --></div><!-- /wp:columns -->"
		},
		{
			"slug": "glossary",
			"title": "Glossary",
			"parent": "knowledge-hub",
			"content": "<!-- wp:group {\"backgroundColor\":\"muted\",\"style\":{\"spacing\":{\"padding\":{\"top\":\"5rem\",\"bottom\":\"5rem\"}}},\"layout\":{\"type\":\"constrained\"}} --><div class=\"wp-block-group has-muted-background-color has-background\" style=\"padding-top:5rem;padding-bottom:5rem\"><!-- wp:pazone/breadcrumbs /--><!-- wp:heading {\"textAlign\":\"center\",\"level\":1} --><h1 class=\"wp-block-heading has-text-align-center\">Glossary</h1><!-- /wp:heading --><!-- wp:paragraph {\"align\":\"center\"} --><p class=\"has-text-align-center\">Plain-English definitions of common Alternative Provision, SEND and safeguarding terms.</p><!-- /wp:paragraph --></div><!-- /wp:group -->\n<!-- wp:list --><ul><li><strong>Alternative Provision (AP)</strong> - education for young people who cannot attend mainstream.</li><li><strong>EHCP</strong> - Education, Health and Care Plan; a legal document for children with SEND.</li><li><strong>SEND</strong> - Special Educational Needs and Disabilities.</li><li><strong>SEN Support</strong> - school-based support for pupils with SEND who do not have an EHCP.</li><li><strong>DfE</strong> - Department for Education.</li><li><strong>LA</strong> - Local Authority.</li><li><strong>CPOMS</strong> - a common safeguarding logging system used in schools.</li><li><strong>DSL</strong> - Designated Safeguarding Lead.</li><li><strong>PEP</strong> - Personal Education Plan for looked-after children.</li><li><strong>LAC</strong> - Looked After Child.</li><li><strong>CME</strong> - Child Missing Education.</li><li><strong>EOTAS</strong> - Education Other Than At School.</li></ul><!-- /wp:list -->"
		},
		{
			"slug": "complete-guide",
			"title": "The Complete Guide to Alternative Provision",
			"parent": "knowledge-hub",
			"content": "<!-- wp:group {\"backgroundColor\":\"muted\",\"style\":{\"spacing\":{\"padding\":{\"top\":\"5rem\",\"bottom\":\"5rem\"}}},\"layout\":{\"type\":\"constrained\"}} --><div class=\"wp-block-group has-muted-background-color has-background\" style=\"padding-top:5rem;padding-bottom:5rem\"><!-- wp:pazone/breadcrumbs /--><!-- wp:heading {\"textAlign\":\"center\",\"level\":1} --><h1 class=\"wp-block-heading has-text-align-center\">The Complete Guide to Alternative Provision</h1><!-- /wp:heading --><!-- wp:paragraph {\"align\":\"center\"} --><p class=\"has-text-align-center\">An end-to-end walkthrough for parents, carers, schools and Local Authorities.</p><!-- /wp:paragraph --></div><!-- /wp:group -->\n<!-- wp:heading {\"level\":2} --><h2>1. What is Alternative Provision?</h2><!-- /wp:heading --><!-- wp:paragraph --><p>Alternative Provision (AP) is education for young people who cannot attend mainstream school for reasons including exclusion, medical need, school refusal or unmet SEND.</p><!-- /wp:paragraph -->\n<!-- wp:heading {\"level\":2} --><h2>2. Who is it for?</h2><!-- /wp:heading --><!-- wp:paragraph --><p>Learners aged 11&ndash;16 who benefit from smaller groups, trauma-informed practice and a relational approach to education.</p><!-- /wp:paragraph -->\n<!-- wp:heading {\"level\":2} --><h2>3. How a referral works</h2><!-- /wp:heading --><!-- wp:pattern {\"slug\":\"pathway-academy-zone/referral-journey\"} /-->\n<!-- wp:heading {\"level\":2} --><h2>4. Safeguarding and pastoral care</h2><!-- /wp:heading --><!-- wp:paragraph --><p>Safeguarding is everyone&apos;s responsibility. Every centre has a DSL, a deputy DSL and clear reporting routes.</p><!-- /wp:paragraph -->\n<!-- wp:heading {\"level\":2} --><h2>5. Outcomes and next steps</h2><!-- /wp:heading --><!-- wp:pazone/stat-grid /-->"
		},
